<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>GF2 IT Dashboard</title>
  <style>
    /* NEG brand-locked · Space Grotesk (lokal) · lyst tjekliste-tema */
    @font-face {
      font-family: "Space Grotesk";
      src: url("{{ .FontDataURI }}") format("woff2");
      font-weight: 300 700;
      font-display: swap;
    }

    :root {
      --navy: #123c62;
      --navy-deep: #0d2f4f;
      --blue: #86afd8;
      --blue-soft: #eaf1f8;
      --grey: #efefef;
      --orange: #ec8113;
      --orange-soft: #fdeed9;
      --ink: #16334d;
      --muted: #5d7184;
      --line: #d8e2ec;
      --surface: #ffffff;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: "Space Grotesk", system-ui, Arial, Helvetica, sans-serif;
      font-weight: 400;
      background: var(--grey);
      color: var(--ink);
    }

    button, a, select { font: inherit; }

    .lbl { font-weight: 500; letter-spacing: .12em; text-transform: uppercase; }

    /* topbar */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 14px 28px;
      background: var(--surface);
      border-bottom: 1px solid var(--line);
    }

    .brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
    .brand .logo { height: 40px; width: auto; display: block; flex: 0 0 auto; }
    .brand .brand-text { font-weight: 700; color: var(--navy); line-height: 1.15; }
    .brand .brand-text small {
      display: block;
      margin-top: 3px;
      color: var(--muted);
      font-weight: 500;
      font-size: 12.5px;
    }

    .mode-toggle {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px;
      padding: 5px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--grey);
      flex: 0 0 auto;
    }

    .mode-toggle button {
      border: 0;
      border-radius: 999px;
      padding: 9px 16px;
      background: transparent;
      color: var(--muted);
      font-weight: 500;
      cursor: pointer;
    }

    .mode-toggle button[aria-pressed="true"] {
      background: var(--navy);
      color: #fff;
    }

    /* helsides 3:1 gitter — hero-billedet deler højre kolonne med sidebaren,
       så billedet har præcis samme bredde som links-boksen nedenunder */
    .shell {
      display: grid;
      grid-template-columns: 3fr 1fr;
    }

    .hero-copy {
      grid-column: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 300px;
      padding: 50px 40px;
      background: var(--navy);
      color: #fff;
    }

    .hero-media {
      grid-column: 2;
      min-height: 300px;
      background:
        url("{{ .HeroDataURI }}") right center / cover no-repeat,
        var(--navy);
    }

    .kicker {
      margin-bottom: 14px;
      color: var(--blue);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: .14em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      max-width: 640px;
      font-size: 44px;
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -.01em;
    }

    .hero-copy p {
      margin: 18px 0 0;
      max-width: 600px;
      color: #dce8f4;
      font-size: 16px;
      line-height: 1.5;
    }

    /* indholdsrækken deler samme kolonner som hero-rækken */
    .col-main { grid-column: 1; padding: 26px 14px 26px 40px; min-width: 0; }
    /* venstre 0-padding = start uændret ved hero/navy-grænsen; 40px højre = samme margen som venstre kolonne har mod kanten */
    .col-side { grid-column: 2; padding: 26px 40px 26px 0; }

    .panel {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
    }

    .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid var(--line);
      font-weight: 700;
      color: var(--navy);
    }

    .panel-header .muted-label {
      font-weight: 500;
      font-size: 12px;
      color: var(--muted);
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    .panel-body { padding: 18px; }

    /* fremgang */
    .progress { margin-bottom: 18px; }
    .progress-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }
    .progress-count { font-weight: 700; color: var(--navy); font-size: 15px; }
    .progress-hint { font-size: 12px; color: var(--muted); }
    .bar {
      height: 10px;
      border-radius: 6px;
      background: var(--grey);
      border: 1px solid var(--line);
      overflow: hidden;
    }
    .bar > i {
      display: block;
      height: 100%;
      width: 0;
      background: var(--blue);
      transition: width .4s ease;
    }

    /* trin — 3 kolonner × 3 høj (8 trin + ét tomt felt), alle kort lige store */
    .steps { display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-rows: 1fr; gap: 14px; }

    .step {
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr);
      gap: 14px;
      align-items: stretch;
      padding: 16px 18px;
      border: 1px solid var(--line);
      border-left: 5px solid var(--line);
      border-radius: 10px;
      background: var(--surface);
      transition: border-color .2s ease, background .2s ease;
    }

    .step.is-done { border-left-color: var(--blue); background: var(--blue-soft); }

    .step-main { display: flex; flex-direction: column; min-width: 0; }

    .num {
      display: grid;
      place-items: center;
      align-self: start;
      width: 44px;
      height: 44px;
      border-radius: 9px;
      background: var(--navy);
      color: #fff;
      font-weight: 700;
      font-size: 17px;
    }
    .step.is-done .num { background: var(--blue); color: var(--navy-deep); }

    .step-head { display: flex; align-items: flex-start; gap: 10px; }
    .step h3 { flex: 1 1 auto; margin: 0 0 6px; font-size: 17px; font-weight: 700; line-height: 1.22; color: var(--navy); }
    .step p { margin: 0; color: var(--muted); font-size: 13.5px; line-height: 1.45; }

    .done-toggle {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      flex: 0 0 auto;
      font-size: 12px;
      font-weight: 700;
      color: var(--muted);
      cursor: pointer;
      white-space: nowrap;
      user-select: none;
    }
    .done-toggle input { width: 18px; height: 18px; margin: 0; accent-color: var(--blue); cursor: pointer; }
    .step.is-done .done-toggle { color: var(--navy); }

    .step-links { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 7px 12px;
      border: 1px solid var(--blue);
      border-radius: 999px;
      background: var(--blue-soft);
      color: var(--navy);
      text-decoration: none;
      font-weight: 500;
      font-size: 13px;
    }
    .chip:hover { background: var(--blue); }
    .chip .arrow { color: var(--orange); font-weight: 700; }

    /* kompakt underviser-visning — samme 2×4 som elev */
    .steps.compact { gap: 12px; }
    .steps.compact .step { grid-template-columns: 34px minmax(0, 1fr); padding: 13px 14px; gap: 12px; }
    .steps.compact .num { width: 34px; height: 34px; font-size: 14px; border-radius: 8px; }
    .steps.compact h3 { font-size: 15.5px; }
    .steps.compact p { font-size: 13px; }
    /* lærer-reminderen (#7) fremhæves med orange, men fylder kun én celle som de øvrige */
    .step.teacher-reminder { border-left-color: var(--orange); background: var(--orange-soft); }

    /* sidebar */
    .primary-action, .secondary-action {
      display: block;
      width: 100%;
      margin-top: 12px;
      border-radius: 9px;
      padding: 14px;
      text-align: center;
      text-decoration: none;
      font-weight: 700;
    }
    .primary-action { border: 0; background: var(--orange); color: #2a1804; }
    .secondary-action { border: 1.5px solid var(--navy); background: #fff; color: var(--navy); }

    .notice {
      margin-top: 14px;
      padding: 13px 14px;
      border-radius: 9px;
      font-size: 14px;
      line-height: 1.45;
      background: var(--orange-soft);
      border: 1px solid var(--orange);
      border-left: 5px solid var(--orange);
      color: #6b3d08;
    }
    .notice.info {
      background: var(--blue-soft);
      border-color: var(--blue);
      border-left-color: var(--blue);
      color: var(--navy);
    }

    .quicklinks { display: grid; gap: 9px; }
    .quicklink {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 14px;
      border: 1px solid var(--line);
      border-radius: 9px;
      background: #fff;
      color: var(--navy);
      text-decoration: none;
      font-weight: 500;
    }
    .quicklink:hover { border-color: var(--blue); background: var(--blue-soft); }
    .quicklink .open { color: var(--orange); font-weight: 700; font-size: 13px; }

    .links-subhead {
      margin: 18px 0 4px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .credit { color: var(--muted); font-size: 12px; font-weight: 500; margin-top: 16px; text-align: right; }

    .manual { margin-top: 18px; }
    .manual summary { cursor: pointer; font-weight: 700; color: var(--navy); }
    .manual ol { margin: 12px 0 0; padding-left: 22px; color: var(--muted); line-height: 1.55; }

    .hidden { display: none; }

    /* responsivt — skole-laptop 1366×768 holder 3:1, smallere falder sammen */
    @media (max-width: 1100px) {
      .shell { grid-template-columns: 1fr; }
      .hero-copy, .hero-media, .col-main, .col-side { grid-column: 1; }
      .hero-media { min-height: 170px; }
      .col-main { padding: 24px 18px 0; }
      .col-side { padding: 0 18px 24px; }
      .steps { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 720px) {
      .topbar { flex-direction: column; align-items: flex-start; }
      .hero-copy { padding: 40px 22px; min-height: 0; }
      h1 { font-size: 32px; }
      .steps, .steps.compact { grid-template-columns: 1fr; }
      .step { grid-template-columns: 40px minmax(0, 1fr); }
    }

    @media (prefers-reduced-motion: reduce) {
      .bar > i, .step { transition: none; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <img class="logo" src="{{ .LogoDataURI }}" alt="NEG">
      <div class="brand-text">
        GF2 IT Dashboard
        <small>Opstart, links og lokal status</small>
      </div>
    </div>
    <div class="mode-toggle" aria-label="Skift mellem elev og underviser">
      <button id="studentMode" type="button" aria-pressed="true">Elev</button>
      <button id="teacherMode" type="button" aria-pressed="false">Underviser</button>
    </div>
  </header>

  <div class="shell">
    <section class="hero-copy">
      <div class="kicker">ET FÆLLESSKAB MED PLADS TIL DIG</div>
      <h1>Kom sikkert i gang med IT på GF2</h1>
      <p>Følg rækkefølgen første skoledag, og brug dashboardet igen når du skal finde Office, Moodle, Lectio, PraxisOnline, OneDrive eller SketchUp.</p>
    </section>
    <div class="hero-media" aria-hidden="true"></div>

    <main class="col-main">
      <section class="panel panel-main" aria-live="polite">
        <div class="panel-header">
          <span id="mainTitle">Opstart første dag</span>
          <span class="muted-label">Status gemmes lokalt</span>
        </div>
        <div class="panel-body">
          <div class="progress">
            <div class="progress-top">
              <span id="progressCount" class="progress-count">0 af 8 færdige</span>
              <span id="progressHint" class="progress-hint">Marker hvert trin når du er klar</span>
            </div>
            <div class="bar"><i id="progressBar"></i></div>
          </div>

          <div id="studentSteps" class="steps"></div>
          <div id="teacherSteps" class="steps compact hidden"></div>

          <details id="manualGuide" class="manual">
            <summary>Manuel vejledning</summary>
            <ol>
              <li>Få dit NEG-brugernavn og din adgangskode udleveret af skolen.</li>
              <li>Log på skolens Wi-Fi med dit NEG-login.</li>
              <li>Åbn Office 365, tjek skolemail, og find SketchUp/Trimble-invitationen.</li>
              <li>Åbn Moodle med samme NEG-login.</li>
              <li>Åbn Lectio og PraxisOnline med MitID.</li>
              <li>Gem dine opgaver i OneDrive via Office 365.</li>
            </ol>
          </details>
        </div>
      </section>
    </main>

    <aside class="col-side">
      <section class="panel">
        <div class="panel-header">Kom i gang &amp; links</div>
        <div class="panel-body">
          <a class="primary-action" href="index.html">Download setup</a>
          <a class="secondary-action" href="#manualGuide">Manuel vejledning</a>

          <div class="links-subhead">Faste links</div>
          <div id="quickLinks" class="quicklinks"></div>

          <div class="notice"><strong>Syg eller fravær?</strong><br>Ring til +45 72 290 100 mellem kl. 8.00-9.00.</div>
          <div class="credit">Udviklet af Jesper Reenberg</div>
        </div>
      </section>
    </aside>
  </div>

  <script>
    // Assistenten indsætter elevens fremdrift her: { "<studentSteps-indeks>": "Færdig" }.
    // Tom {} når filen ikke er genereret af Assistenten (fx den hostede side).
    const assistentStudentStatus = {{ .StudentStatusJSON }};

    // Link-data: én ren, identificerbar blok (forberedt til #30 Go-SSOT).
    // Selvbetjening bruges af både elever (skift egen adgangskode) og undervisere (udskriv bruger).
    const links = [
      { key: "office",        label: "Office 365 / skolemail", url: "https://www.office.com/",                              audience: "all" },
      { key: "moodle",        label: "Moodle",                 url: "https://online.neg.dk/login/index.php",                audience: "all" },
      { key: "lectio",        label: "Lectio",                 url: "https://www.lectio.dk/lectio/769/default.aspx",        audience: "all" },
      { key: "praxis",        label: "PraxisOnline",           url: "https://online.praxis.dk/",                            audience: "all" },
      { key: "onedrive",      label: "OneDrive",               url: "https://www.office.com/launch/onedrive",               audience: "all" },
      { key: "sketchup",      label: "SketchUp / Trimble",     url: "https://sketchup.trimble.com/",                        audience: "all" },
      { key: "neg",           label: "NEG hjemmeside",         url: "https://www.neg.dk/",                                  audience: "all" },
      { key: "selvbetjening", label: "NEG selvbetjening",      url: "https://selvbetjening.neg.dk/UMSLogin/weblogin.aspx?ReturnUrl=%2f", audience: "all" }
    ];

    const linkByKey = Object.fromEntries(links.map(link => [link.key, link]));

    const studentSteps = [
      { title: "Få NEG-login", body: "Få udleveret NEG-brugernavn og adgangskode. Skriv ikke oplysningerne i dashboardet. Du kan selv skifte din adgangskode på NEG selvbetjening.", links: ["selvbetjening"] },
      { title: "Log på skolens Wi-Fi", body: "Brug dit NEG-login til skolens netværk før du åbner de øvrige systemer.", links: [] },
      { title: "Åbn Office 365 og skolemail", body: "Log på Office.com og kontroller at du kan læse skolemail.", links: ["office"] },
      { title: "Find SketchUp/Trimble-invitationen", body: "Åbn skolemailen og find invitationen til SketchUp/Trimble-flowet.", links: ["office"] },
      { title: "Log på Moodle", body: "Brug samme NEG-login til Moodle og tjek at dine GF2-rum vises.", links: ["moodle"] },
      { title: "Log på PraxisOnline og Lectio", body: "Brug MitID til PraxisOnline og Lectio. Dashboardet kan kun åbne siderne.", links: ["praxis", "lectio"] },
      { title: "Installer eller åbn SketchUp", body: "Installer SketchUp hvis nødvendigt, og opret eller log ind på Trimble-profil via skolemail-flowet.", links: ["sketchup"] },
      { title: "Gem opgaver i OneDrive", body: "Brug OneDrive via Office 365 som fast sted til opgaver og filer.", links: ["onedrive"] }
    ];

    const teacherSteps = [
      { title: "Tjek Wi-Fi", body: "Bekræft at eleven er på skolens Wi-Fi med NEG-login.", links: [] },
      { title: "Bekræft Office og skolemail", body: "Kontroller at Office.com virker, og at eleven kan åbne skolemail.", links: ["office"] },
      { title: "Bekræft Moodle", body: "Kontroller at Moodle virker med elevens NEG-login.", links: ["moodle"] },
      { title: "Forklar SketchUp og Trimble", body: "Scriptet kan hjælpe med installation, men Trimble/licens kræver elevens skolemail-flow.", links: ["sketchup"] },
      { title: "Forklar MitID-sporet", body: "Lectio og PraxisOnline kræver MitID. Scriptet kan kun åbne de rigtige sider.", links: ["praxis", "lectio"] },
      { title: "Bekræft OneDrive", body: "Eleven skal bruge OneDrive til filer. FileCloud/P-drev er ikke en del af elevflowet.", links: ["onedrive"] },
      { title: "Tjek typiske fejl", body: "Windows S-mode, Chromebook, forkert login, manglende skolemail og manglende MitID er de hyppigste blokeringer.", links: [] },
      { title: "Elev har glemt mail eller login?", body: "Log ind på NEG selvbetjening, find eleven og vælg „udskriv bruger”. Eleven får sit brugernavn og den aktive adgangskode. Dashboardet linker kun ud — det gemmer ingen oplysninger.", links: ["selvbetjening"], reminder: true }
    ];

    const storage = {
      mode: "gf2-it-dashboard.mode",
      student: "gf2-it-dashboard.studentStatus",
      teacher: "gf2-it-dashboard.teacherStatus"
    };

    function readJson(key, fallback) {
      try {
        const value = JSON.parse(localStorage.getItem(key));
        return value || fallback;
      } catch {
        return fallback;
      }
    }

    function writeJson(key, value) {
      localStorage.setItem(key, JSON.stringify(value));
    }

    function makeQuicklink(link) {
      const a = document.createElement("a");
      a.className = "quicklink";
      a.href = link.url;
      a.target = "_blank";
      a.rel = "noopener noreferrer";
      a.innerHTML = `<span>${link.label}</span><span class="open">Åbn ›</span>`;
      return a;
    }

    function renderLinks() {
      const all = document.getElementById("quickLinks");
      all.innerHTML = "";
      links.forEach(link => all.appendChild(makeQuicklink(link)));
    }

    function makeChip(key) {
      const link = linkByKey[key];
      if (!link) return null;
      const a = document.createElement("a");
      a.className = "chip";
      a.href = link.url;
      a.target = "_blank";
      a.rel = "noopener noreferrer";
      a.innerHTML = `<span>${link.label}</span><span class="arrow">›</span>`;
      return a;
    }

    function applyStepState(article, status, index) {
      const done = status === "Færdig";
      article.classList.toggle("is-done", done);
      const num = article.querySelector(".num");
      num.textContent = done ? "✓" : String(index + 1);
    }

    function renderSteps(targetId, items, key, mode) {
      const holder = document.getElementById(targetId);
      const statuses = readJson(key, {});
      holder.innerHTML = "";
      items.forEach((item, index) => {
        const article = document.createElement("article");
        article.className = item.reminder ? "step teacher-reminder" : "step";
        const current = statuses[index] === "Færdig" ? "Færdig" : "Ikke startet";
        const inputId = `${targetId}-${index}`;

        const chips = (item.links || [])
          .map(makeChip)
          .filter(Boolean);
        const linksHtml = chips.length ? `<div class="step-links"></div>` : "";

        article.innerHTML = `
          <div class="num" aria-hidden="true">${index + 1}</div>
          <div class="step-main">
            <div class="step-head">
              <h3>${item.title}</h3>
              <label class="done-toggle" for="${inputId}">
                <input type="checkbox" id="${inputId}" ${current === "Færdig" ? "checked" : ""}>
                <span>Færdig</span>
              </label>
            </div>
            <p>${item.body}</p>
            ${linksHtml}
          </div>
        `;

        if (chips.length) {
          const linkHolder = article.querySelector(".step-links");
          chips.forEach(chip => linkHolder.appendChild(chip));
        }

        applyStepState(article, current, index);

        const checkbox = article.querySelector('input[type="checkbox"]');
        checkbox.addEventListener("change", () => {
          const status = checkbox.checked ? "Færdig" : "Ikke startet";
          statuses[index] = status;
          writeJson(key, statuses);
          applyStepState(article, status, index);
          updateProgress(mode);
        });

        holder.appendChild(article);
      });
    }

    function updateProgress(mode) {
      const items = mode === "teacher" ? teacherSteps : studentSteps;
      const key = mode === "teacher" ? storage.teacher : storage.student;
      const statuses = readJson(key, {});
      const done = items.reduce((sum, _item, index) => sum + (statuses[index] === "Færdig" ? 1 : 0), 0);
      const total = items.length;
      const noun = mode === "teacher" ? "gennemgået" : "færdige";
      document.getElementById("progressCount").textContent = `${done} af ${total} ${noun}`;
      document.getElementById("progressHint").textContent = done === total
        ? (mode === "teacher" ? "Alle trin gennemgået" : "Alle trin er færdige – godt gået!")
        : (mode === "teacher" ? "Marker hvert trin når det er verificeret" : "Marker hvert trin når du er klar");
      document.getElementById("progressBar").style.width = `${Math.round((done / total) * 100)}%`;
    }

    function fillStudentStatus(status) {
      const statuses = {};
      studentSteps.forEach((_, index) => {
        statuses[index] = status;
      });
      writeJson(storage.student, statuses);
    }

    function applySetupCompletionFromUrl() {
      const params = new URLSearchParams(window.location.search);
      if (params.get("setup") !== "complete") {
        return;
      }

      fillStudentStatus("Færdig");
      localStorage.setItem(storage.mode, "student");
      const cleanUrl = window.location.href
        .replace(/[?&]setup=complete\b/, "")
        .replace("?&", "?")
        .replace(/\?$/, "");
      window.history.replaceState({}, document.title, cleanUrl);
    }

    function setMode(mode) {
      localStorage.setItem(storage.mode, mode);
      const isTeacher = mode === "teacher";
      document.getElementById("studentMode").setAttribute("aria-pressed", String(!isTeacher));
      document.getElementById("teacherMode").setAttribute("aria-pressed", String(isTeacher));
      document.getElementById("studentSteps").classList.toggle("hidden", isTeacher);
      document.getElementById("teacherSteps").classList.toggle("hidden", !isTeacher);
      document.getElementById("mainTitle").textContent = isTeacher ? "Underviser-tjekliste" : "Opstart første dag";
      updateProgress(mode);
    }

    document.getElementById("studentMode").addEventListener("click", () => setMode("student"));
    document.getElementById("teacherMode").addEventListener("click", () => setMode("teacher"));

    // Når Assistenten har genereret filen, sætter vi elevens flueben før
    // første render, så trinnene står markeret som færdige med det samme.
    function applyAssistentStatus() {
      const keys = Object.keys(assistentStudentStatus);
      if (keys.length === 0) return;
      const statuses = readJson(storage.student, {});
      keys.forEach(index => { statuses[index] = assistentStudentStatus[index]; });
      writeJson(storage.student, statuses);
      localStorage.setItem(storage.mode, "student");
    }

    applySetupCompletionFromUrl();
    applyAssistentStatus();
    renderLinks();
    renderSteps("studentSteps", studentSteps, storage.student, "student");
    renderSteps("teacherSteps", teacherSteps, storage.teacher, "teacher");
    setMode(localStorage.getItem(storage.mode) || "student");
  </script>
</body>
</html>
